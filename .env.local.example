# ═══════════════════════════════════════════════════════════════════════════════
# FallCon Ticket Conductor — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# QUICK START
# ───────────
# 1. Copy this file to .env.local
# 2. Fill in the three REQUIRED Supabase values and generate a SYSTEM_SECRET
# 3. Deploy / start the dev server
# 4. Go to /admin/settings in the app and use the "System Configuration" section
#    to enter your Resend API key, email addresses, and any other credentials
#    — no more editing .env files for API keys!
#
# The admin UI stores secrets encrypted in your Supabase DB (AES-256-GCM).
# The ONLY keys you must set at the infrastructure level are below.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── REQUIRED — Supabase connection ───────────────────────────────────────────
# Set these at deploy time. They cannot be changed via the in-app UI.
# Find them in your Supabase project: Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─── REQUIRED — Encryption key for in-app secrets ─────────────────────────────
# Used to encrypt API keys stored in the system_config table.
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT:
#   • Must be at least 16 characters (32-byte hex string strongly recommended)
#   • Changing this after setup will render all stored secrets unreadable
#   • Back this up somewhere safe — losing it means re-entering all API keys

SYSTEM_SECRET=your_32_char_random_hex_string_here


# ─── OPTIONAL — Can be set here OR in Admin > Settings > System Config ─────────
#
# If a value is set in BOTH places, the Admin UI (database) value takes precedence.
# This means you can start with env vars during initial setup, then migrate to
# the in-app UI for easier credential rotation without touching server config.
#
# Supported in-app config keys (Admin > Settings > System Config):
#   resend_api_key        — Resend API key for transactional email
#   resend_from_email     — From address for outgoing email
#   resend_from_name      — Display name for outgoing email
#   app_url               — Canonical public URL of this deployment
#   app_name              — App display name (shown in UI and emails)
#   support_email         — Support contact shown to attendees
#   connect_api_url       — Connect integration API base URL
#   connect_api_key       — Connect integration API key (encrypted)

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=FallCon Tickets

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FallCon Ticket Conductor


# ─── OPTIONAL — Connect Integration (future) ──────────────────────────────────
# These can also be set via Admin > Settings > System Config > Connect tab.

CONNECT_API_URL=
CONNECT_API_KEY=
